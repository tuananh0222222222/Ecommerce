<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>404 Not Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>

        .error-container {
          text-align: center;
        }
        .error-code {
          font-size: 5rem;
          font-weight: bold;
          color: #dc3545;
        }
        .error-message {
          font-size: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code">404</div>
        <div class="error-message">Oops! Trang bạn tìm không tồn tại.</div>
        <a href="/" class="btn btn-primary mt-4">Về trang chủ</a>
    </div>
</body>
</html>
