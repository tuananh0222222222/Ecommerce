<h2>Sản phẩm</h2>

<!-- Hiệu ứng loading (spinner) -->
<div id="loading" style="display: none;" class="text-center mt-4">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<!-- Tạo bảng với Bootstrap -->
<table class="table table-striped table-bordered mt-4" id="productTable" style="display: none;">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
            <th>Description</th>
            <th>Stock Quantity</th>
            <th>Category</th>
            <th>Updated At</th>
            <th>Created At</th>
        </tr>
    </thead>
    <tbody id="productList">
        <!-- Dữ liệu sản phẩm sẽ được thêm vào đây -->
    </tbody>
</table>

<!-- Thêm Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function loadProducts() {
      // Hiển thị loading, ẩn bảng sản phẩm
      $("#loading").show();
      $("#productTable").hide();

      $.ajax({
        url: "http://4.200.9.115:8088/api/product/",
        method: "GET",
        success: function (data) {
          // Ẩn loading, hiển thị bảng
          $("#loading").hide();
          $("#productTable").show();

          // Xóa hết dữ liệu cũ trước khi thêm dữ liệu mới
          $("#productList").empty();

          // Duyệt qua từng sản phẩm và thêm vào bảng
          data.forEach(product => {
            $("#productList").append(`
              <tr>
                <td>${product.id}</td>
                <td>${product.name}</td>
                <td>${product.price}</td>
                <td>${product.description}</td>
                <td>${product.stockQuantity}</td>
                <td>${product.category}</td>
                <td>${product.updatedAt}</td>
                <td>${product.createdAt}</td>
              </tr>
            `);
          });
        },
        error: function (err) {
          alert("Lỗi khi tải dữ liệu.");
          console.error(err);
          $("#loading").hide();
        }
      });
    }

    // Tự động tải dữ liệu mỗi 5 giây
    setInterval(loadProducts, 5000);  // 5000ms = 5 giây

    // Lần đầu tiên tải khi trang được load
    loadProducts();
</script>
